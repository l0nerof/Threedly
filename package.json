{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./scripts/local-supabase.mjs dev",
    "dev:remote": "node ./scripts/local-supabase.mjs dev --remote",
    "db:start": "node ./scripts/local-supabase.mjs start",
    "db:reset": "node ./scripts/local-supabase.mjs reset",
    "db:seed": "node ./scripts/local-supabase.mjs seed",
    "build": "next build",
    "start": "next start",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:unit:watch": "vitest",
    "format": "prettier --write --ignore-unknown .",
    "format:check": "prettier --check --ignore-unknown .",
    "lint": "eslint",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown",
    "*.{js,jsx,ts,tsx}": "eslint --fix"
  },
