    "motion": "^12.29.2",
    "next": "^16.2.3",
    "next-intl": "^4.11.0",
    "next-themes": "^0.4.6",
    "ogl": "^1.0.11",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
